---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const posts = (await getCollection("posts", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.localeCompare(a.data.date));
---

<Layout title="Home" description="YangPeter's blog — tech & life">
  <section class="hero">
    <div class="avatar">
      <div class="avatar-inner">
        <img src="/avatar.jpg" alt="YangPeter" />
      </div>
    </div>
    <h1>YangPeter</h1>
    <p class="tagline">Cybersecurity Engineer · Lifelong Learner</p>
    <p class="bio">
      Forever learning, forever curious. Notes on tech, projects, and source code deep-dives.
    </p>
  </section>

  {posts.map((post) => (
    <a class="card liquid-glass" href={`/posts/${post.id}/`}>
      <div class="card-meta">
        <span class="card-date">{post.data.date}</span>
        {post.data.tags.map((tag, i) => (
          <span class={`card-tag ${i === 0 ? "accent" : ""}`}>{tag}</span>
        ))}
      </div>
      <h2 class="card-title">{post.data.title}</h2>
      <p class="card-excerpt">{post.data.excerpt}</p>
      <div class="card-footer">
        <span>Read &rarr;</span>
      </div>
    </a>
  ))}
</Layout>
