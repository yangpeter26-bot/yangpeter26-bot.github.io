---
// src/layouts/Layout.astro
export interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || "YangPeter's tech blog"} />
    <title>{title} | YangPeter</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+SC:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --glass: rgba(255, 255, 255, 0.6);
        --glass-border: rgba(255, 255, 255, 0.8);
        --glass-shadow: 0 8px 32px rgba(0, 0, 0, 0.06);
        --glass-hover: rgba(255, 255, 255, 0.85);
        --bg: #f0f2f5;
        --text: #1a1a2e;
        --text-dim: #5a5a72;
        --purple: #7c3aed;
        --cyan: #0891b2;
        --pink: #db2777;
        --radius: 20px;
      }

      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: "Inter", "Noto Sans SC", -apple-system, sans-serif;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
        line-height: 1.7;
        overflow-x: hidden;
      }

      /* --- 液态金属背景 --- */
      .bg-deco {
        position: fixed;
        border-radius: 50%;
        filter: blur(180px);
        opacity: 0.4;
        pointer-events: none;
        z-index: 0;
        animation: float 12s ease-in-out infinite;
      }
      .bg-deco-1 {
        width: 600px;
        height: 600px;
        background: linear-gradient(135deg, #c4b5fd, #a5f3fc);
        top: -200px;
        right: -200px;
      }
      .bg-deco-2 {
        width: 400px;
        height: 400px;
        background: linear-gradient(135deg, #f9a8d4, #c4b5fd);
        bottom: -150px;
        left: -100px;
        animation-delay: -6s;
      }
      @keyframes float {
        0%,
        100% {
          transform: translate(0, 0) scale(1);
        }
        50% {
          transform: translate(40px, -50px) scale(1.08);
        }
      }

      /* --- 毛玻璃导航 --- */
      .nav {
        position: sticky;
        top: 0;
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 32px;
        background: var(--glass);
        backdrop-filter: blur(24px) saturate(180%);
        -webkit-backdrop-filter: blur(24px) saturate(180%);
        border-bottom: 1px solid var(--glass-border);
      }
      .nav-brand {
        font-size: 20px;
        font-weight: 700;
        background: linear-gradient(135deg, var(--purple), var(--cyan));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .nav-links {
        display: flex;
        gap: 28px;
        list-style: none;
      }
      .nav-links a {
        color: var(--text-dim);
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        transition: color 0.2s;
      }
      .nav-links a:hover {
        color: var(--text);
      }

      /* --- 容器 --- */
      .container {
        position: relative;
        z-index: 1;
        max-width: 760px;
        margin: 0 auto;
        padding: 0 24px;
      }

      /* --- Hero --- */
      .hero {
        margin-top: 60px;
        margin-bottom: 64px;
        text-align: center;
      }
      .avatar {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--purple), var(--cyan), var(--pink));
        padding: 3px;
        margin: 0 auto 24px;
        animation: avatarGlow 4s ease-in-out infinite;
      }
      .avatar-inner {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        background: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 38px;
        overflow: hidden;
      }
      .avatar-inner img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      @keyframes avatarGlow {
        0%,
        100% {
          box-shadow: 0 0 20px rgba(124, 58, 237, 0.15);
        }
        50% {
          box-shadow: 0 0 50px rgba(124, 58, 237, 0.3), 0 0 90px rgba(8, 145, 178, 0.1);
        }
      }
      .hero h1 {
        font-size: 36px;
        font-weight: 700;
        margin-bottom: 10px;
      }
      .hero .tagline {
        color: var(--text-dim);
        font-size: 16px;
        margin-bottom: 20px;
      }
      .hero .bio {
        color: var(--text-dim);
        font-size: 14px;
        max-width: 480px;
        margin: 0 auto;
        line-height: 1.9;
      }

      /* --- 毛玻璃卡片 --- */
      .card {
        display: block;
        text-decoration: none;
        color: inherit;
        background: var(--glass);
        backdrop-filter: blur(16px) saturate(180%);
        -webkit-backdrop-filter: blur(16px) saturate(180%);
        border: 1px solid var(--glass-border);
        border-radius: var(--radius);
        padding: 28px 32px;
        margin-bottom: 16px;
        transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
        cursor: pointer;
        box-shadow: var(--glass-shadow);
      }
      .card:hover {
        transform: translateY(-4px);
        background: var(--glass-hover);
        border-color: var(--purple);
        box-shadow: 0 12px 40px rgba(124, 58, 237, 0.1);
      }
      .card-meta {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 10px;
      }
      .card-date {
        font-size: 13px;
        color: var(--text-dim);
      }
      .card-tag {
        font-size: 11px;
        padding: 3px 10px;
        border-radius: 20px;
        background: rgba(139, 92, 246, 0.1);
        color: var(--purple);
        font-weight: 500;
        letter-spacing: 0.04em;
      }
      .card-tag.accent {
        background: rgba(8, 145, 178, 0.1);
        color: var(--cyan);
      }
      .card-tag.warm {
        background: rgba(219, 39, 119, 0.1);
        color: var(--pink);
      }
      .card-title {
        font-size: 20px;
        font-weight: 600;
        margin-bottom: 8px;
      }
      .card-excerpt {
        font-size: 14px;
        color: var(--text-dim);
        line-height: 1.8;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .card-footer {
        display: flex;
        align-items: center;
        gap: 24px;
        margin-top: 16px;
        font-size: 12px;
        color: var(--text-dim);
      }

      /* --- 文章页 --- */
      .prose {
        background: var(--glass);
        backdrop-filter: blur(16px) saturate(180%);
        -webkit-backdrop-filter: blur(16px) saturate(180%);
        border: 1px solid var(--glass-border);
        border-radius: var(--radius);
        padding: 40px 36px;
        margin-top: 40px;
        margin-bottom: 80px;
        box-shadow: var(--glass-shadow);
      }
      .prose h1 {
        font-size: 28px;
        margin-bottom: 12px;
      }
      .prose .date {
        color: var(--text-dim);
        font-size: 13px;
        margin-bottom: 28px;
      }
      .prose p {
        font-size: 16px;
        line-height: 2;
        color: var(--text-dim);
        margin-bottom: 20px;
      }
      .prose hr {
        border: none;
        border-top: 1px solid var(--glass-border);
        margin: 32px 0;
      }
      .back-link {
        color: var(--purple);
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
      }
      .back-link:hover {
        text-decoration: underline;
      }

      /* --- 页脚 --- */
      .footer {
        text-align: center;
        padding: 40px 24px;
        color: var(--text-dim);
        font-size: 13px;
      }
      .footer-links {
        display: flex;
        justify-content: center;
        gap: 24px;
        margin-bottom: 16px;
        flex-wrap: wrap;
      }
      .footer-links a {
        color: var(--text-dim);
        text-decoration: none;
        font-weight: 500;
        transition: color 0.2s;
      }
      .footer-links a:hover {
        color: var(--purple);
      }

      @media (max-width: 640px) {
        .nav {
          padding: 12px 16px;
        }
        .nav-links {
          display: none;
        }
        .hero {
          margin-top: 40px;
          margin-bottom: 48px;
        }
        .hero h1 {
          font-size: 28px;
        }
        .card,
        .prose {
          padding: 20px 20px;
        }
      }
    </style>
  </head>
  <body>
    <div class="bg-deco bg-deco-1"></div>
    <div class="bg-deco bg-deco-2"></div>

    <nav class="nav">
      <a href="/" style="text-decoration:none;" class="nav-brand">YangPeter</a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/posts/about/">About</a></li>
      </ul>
    </nav>

    <main class="container">
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-links">
        <a href="https://github.com/yangpeter26-bot" target="_blank" rel="noopener">GitHub</a>
        <a href="/rss.xml">RSS</a>
        <a href="https://mail.google.com/mail/?view=cm&to=yangpeter26@gmail.com" target="_blank">Email</a>
      </div>
      <p>&copy; 2026 YangPeter &mdash; Built with Astro &amp; Liquid Glass</p>
    </footer>
  </body>
</html>
